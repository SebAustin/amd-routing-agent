# Fireworks AI credentials — copy to .env and fill in real values.
# NEVER commit the real .env file (it is gitignored).
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Comma-separated Fireworks model ids allowed for routing. Also accepts a
# JSON array, or bare names with/without the "accounts/fireworks/models/"
# prefix — config.py normalizes all forms to full ids.
ALLOWED_MODELS=accounts/fireworks/models/gpt-oss-20b,accounts/fireworks/models/deepseek-v4-flash,accounts/fireworks/models/glm-5p1

# Port for the demo webapp (routing_agent.webapp). Optional — defaults to
# 8000 if unset. Not used by adapter.py (harness mode).
PORT=8000
